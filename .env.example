# Copy this file to .env and fill in your own values.
# .env is gitignored - never commit real secrets.

DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---------------------------------------------------------
# Leave DB_ENGINE unset (or set it to "mysql") to use MariaDB, which is
# what this project is required to run on. Set DB_ENGINE=sqlite3 instead
# if you just want to quickly run the automated test suite without a
# MariaDB server installed.
DB_ENGINE=mysql
DB_NAME=newsapp_db
DB_USER=newsapp_user
DB_PASSWORD=yourpassword
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Email --------------------------------------------------------------
# Defaults to printing emails to the console. Switch to the SMTP backend
# to send real emails (e.g. via Gmail's SMTP server with an app password).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=news@example.com

# --- Internal "approved articles" API endpoint --------------------------
# The article-approval signal POSTs here. Point it at wherever this
# project itself is running.
APPROVED_ARTICLE_API_URL=http://127.0.0.1:8000/api/approved/
